# Discord Bot Configuration
DISCORD_TOKEN=your_token_here
GUILD_ID=          # Your guild ID (integer). Remove this comment before using.

# Bot Identity
BOT_NAME=Astra
BOT_THEME_COLOR=3448893

# Database
DATABASE_URL=sqlite:///./data/astra.db

# Dashboard OAuth2 (get these from discord.com/developers/applications)
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Dashboard URLs
# DASHBOARD_API_URL: the Railway/host URL where the bot API runs
# DASHBOARD_FRONTEND_URL: the URL where dashboard/index.html is served
DASHBOARD_API_URL=https://your-railway-app.up.railway.app
DASHBOARD_FRONTEND_URL=https://yourusername.github.io/astra/dashboard

# Secret for signing dashboard session tokens (generate a random string)
DASHBOARD_SECRET=change-me-to-a-long-random-string
